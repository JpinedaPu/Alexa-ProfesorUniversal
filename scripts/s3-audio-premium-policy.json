{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowLambdaUploadAudioPremium",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:PutObjectAcl"
      ],
      "Resource": "arn:aws:s3:::alexa-profesor-universal-cache-us-east-1/audio/premium/*"
    },
    {
      "Sid": "PublicReadAudioPremium",
      "Effect": "Allow",
      "Principal": "*",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::alexa-profesor-universal-cache-us-east-1/audio/premium/*"
    }
  ]
}
