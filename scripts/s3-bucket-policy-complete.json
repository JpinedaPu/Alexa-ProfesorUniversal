{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PublicReadLogos",
      "Effect": "Allow",
      "Principal": "*",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::alexa-profesor-universal-cache-us-east-1/logos/*"
    },
    {
      "Sid": "PublicReadAudioPremium",
      "Effect": "Allow",
      "Principal": "*",
      "Action": "s3:GetObject",
      "Resource": "arn:aws:s3:::alexa-profesor-universal-cache-us-east-1/audio/premium/*"
    }
  ]
}
